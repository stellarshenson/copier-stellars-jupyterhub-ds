# =============================================================================
# CIFS Volume Mount - Remote NAS for large datasets
# =============================================================================
# Enabled via ENABLE_CIFS=1 in .env
# =============================================================================

volumes:
  # Override the base hub_shared volume (mounted at /mnt/shared in the hub) so
  # its data lives on a remote CIFS/SMB share instead of a local volume. The
  # key MUST be hub_shared to merge onto the base volume; with no `name:` it
  # keeps the base's namespaced docker name (${COMPOSE_PROJECT_NAME}_hub_shared).
  hub_shared:
    driver: local
    driver_opts:
      type: cifs
      device: //nas.example.com/share
      o: username=YOUR_USER,password=YOUR_PASSWORD,uid=1000,gid=1000,vers=3.0

# EOF
