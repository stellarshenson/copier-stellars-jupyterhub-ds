#!/bin/bash
# Start {{ project_name }} platform
# Usage: ./start.sh [--refresh]
#   --refresh   re-download compose.yml from the upstream repo AND
#               pull latest docker images. Without --refresh the script uses
#               whatever compose.yml is on disk (downloaded once on
#               first run if missing).
#
# The upstream platform is consumed as a single compose file pulled from
# https://raw.githubusercontent.com/stellarshenson/stellars-jupyterhub-ds/main/compose.yml
# - no full git clone, no submodule. The image stellars/duoptimum-hub:latest
# is pulled from Docker Hub instead of being built locally; the
# pull_policy is overridden in compose_override.yml.

set -e

cd "$(dirname "$0")"

REFRESH=0
for arg in "$@"; do
    case "$arg" in
        --refresh) REFRESH=1 ;;
        *) echo "Unknown option: $arg" >&2; exit 2 ;;
    esac
done

# Load defaults, then local overrides
source env.default
if [[ -f .env ]]; then
    source .env
fi

# Bootstrap self-signed TLS cert on first run.
# Traefik's file provider watches certs/ for certs.yml; if it is not present,
# call certs_generate.sh with no args (sources certs/certs.params for CN +
# altnames). Skip silently on subsequent runs.
if [[ ! -f certs/certs.yml ]]; then
    if [[ ! -f certs/certs_generate.sh ]]; then
        echo "ERROR: certs/certs_generate.sh not found - cannot bootstrap TLS cert." >&2
        echo "       Re-run 'copier copy --trust' or 'copier update --trust' to render it." >&2
        exit 1
    fi
    echo "No TLS cert found in certs/ - generating from certs/certs.params..."
    (cd certs && bash certs_generate.sh)
    if [[ ! -f certs/certs.yml ]]; then
        echo "ERROR: cert generation completed but certs/certs.yml was not produced." >&2
        exit 1
    fi
fi

# Upstream compose file - downloaded from the platform repo, gitignored locally.
UPSTREAM_COMPOSE="compose.yml"
UPSTREAM_COMPOSE_URL="https://raw.githubusercontent.com/stellarshenson/stellars-jupyterhub-ds/main/compose.yml"

# Download on first run if missing; --refresh re-downloads unconditionally.
if [[ "$REFRESH" == "1" || ! -f "$UPSTREAM_COMPOSE" ]]; then
    echo "Fetching $UPSTREAM_COMPOSE from $UPSTREAM_COMPOSE_URL..."
    if ! curl -fsSL "$UPSTREAM_COMPOSE_URL" -o "$UPSTREAM_COMPOSE.tmp"; then
        echo "ERROR: failed to download $UPSTREAM_COMPOSE_URL" >&2
        rm -f "$UPSTREAM_COMPOSE.tmp"
        exit 1
    fi
    mv "$UPSTREAM_COMPOSE.tmp" "$UPSTREAM_COMPOSE"
fi

# Build compose command
COMPOSE_FILES="--env-file env.default"
if [[ -f .env ]]; then
    COMPOSE_FILES="${COMPOSE_FILES} --env-file .env"
fi
COMPOSE_FILES="${COMPOSE_FILES} -f $UPSTREAM_COMPOSE -f compose_override.yml"
{%- if cifs_shared_mount %}
if [[ "${ENABLE_CIFS}" == "1" ]]; then
    echo "CIFS mount enabled"
    COMPOSE_FILES="${COMPOSE_FILES} -f compose_cifs.yml"
fi
{%- endif %}

# Docker image pull is also gated by --refresh; without it, reuse whatever
# images are already on the host (faster startup, no network round-trip).
if [[ "$REFRESH" == "1" ]]; then
    echo "Pulling latest images..."
    docker compose ${COMPOSE_FILES} pull --ignore-pull-failures
fi

echo "Starting {{ project_name }} platform..."
docker compose ${COMPOSE_FILES} up -d --no-build

echo "Done. Access: https://${JUPYTERHUB_HOSTNAME_PREFIX:-{% set subs = jupyterhub_subdomain.split(',') | map('trim') | map('lower') | select | unique | list %}{% if subs %}{{ subs[0] }}.{% endif %}}${BASE_HOSTNAME:-{{ base_hostname }}}/"
