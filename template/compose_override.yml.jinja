# =============================================================================
# Compose Override - {{ project_name }}
# Local Traefik with self-signed certificates and {{ project_name }} branding.
# =============================================================================
#
# PORTS:  80 (HTTP -> redirects to 443)  |  443 (HTTPS)
# CERT:   Self-signed cert in ./certs/
# ACCESS: https://${JUPYTERHUB_PREFIX}${BASE_HOSTNAME}/
#
# Set BASE_HOSTNAME and JUPYTERHUB_PREFIX in .env.
# =============================================================================

services:

  traefik:
    image: traefik:latest
    command:
      # Entrypoints
      - "--entrypoints.web.address=:80"
      - "--entrypoints.websecure.address=:443"
      - "--entrypoints.websecure.http.tls=true"

      # Docker provider
      - "--providers.docker=true"
      - "--providers.docker.exposedbydefault=false"

      # File provider for TLS certificates
      - "--providers.file.directory=/certs"
      - "--providers.file.watch=true"

      # API and Dashboard
      - "--api.dashboard=true"
      - "--api.insecure=false"

      # TLS configuration
      - "--serverstransport.insecureskipverify=true"

      # Logging
      - "--log.level=INFO"
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - ./certs:/certs:ro
    networks:
      - jupyterhub_network
    labels:
      - "traefik.enable=true"

      # Global HTTP->HTTPS redirect
      - "traefik.http.routers.http-catchall.rule=HostRegexp(`.+`)"
      - "traefik.http.routers.http-catchall.entrypoints=web"
      - "traefik.http.routers.http-catchall.middlewares=redirect-to-https"
      - "traefik.http.routers.http-catchall.priority=1"
      - "traefik.http.middlewares.redirect-to-https.redirectscheme.scheme=https"
      - "traefik.http.middlewares.redirect-to-https.redirectscheme.permanent=true"

      # Dashboard: traefik.${BASE_HOSTNAME}
      - "traefik.http.routers.dashboard.rule=Host(`traefik.${BASE_HOSTNAME}`) || HostRegexp(`^traefik(\\..+)?\\.localhost$`)"
      - "traefik.http.routers.dashboard.entrypoints=websecure"
      - "traefik.http.routers.dashboard.tls=true"
      - "traefik.http.routers.dashboard.service=api@internal"
    restart: unless-stopped

  duoptimumhub:
    # Override upstream's `pull_policy: build` - we don't have the Dockerfile
    # context locally (no upstream clone). Pull stellars/duoptimumhub
    # from Docker Hub instead.
    pull_policy: missing
    ports: []
    environment:
      # main settings
      - JUPYTERHUB_BASE_URL=/
      - JUPYTERHUB_ADMIN={{ admin_username }} # initial admin username
      - JUPYTERHUB_ADMIN_PASSWORD=${JUPYTERHUB_ADMIN_PASSWORD:-} # optional INITIAL admin password from .env; ignored once admin sets one in the UI
      - JUPYTERHUB_IDLE_CULLER_ENABLED={% if idle_culler_enabled %}1{% else %}0{% endif %} # culler 0=disabled, 1=enabled
      - JUPYTERHUB_IDLE_CULLER_MAX_EXTENSION=48 # max hours users can extend session
      - JUPYTERHUB_SIGNUP_ENABLED={% if signup_enabled %}1{% else %}0{% endif %} # user self-registration: 0=disabled, 1=enabled
      - JUPYTERHUB_LAB_IMAGE=stellars/stellars-jupyterlab-ds:latest # user container image
      - JUPYTERHUB_TIMEZONE={{ timezone }} # timezone for hub and lab

      # branding ({{ project_name }})
      - JUPYTERHUB_BRANDING_STAGE= # environment-stage header badge: DEV/STG/TST/PRD or custom text; empty = no badge
      - JUPYTERHUB_BRANDING_LOGO_URI=file:///srv/branding/{{ branding_prefix }}_jh_logo.png
      - JUPYTERHUB_BRANDING_FAVICON_URI=file:///srv/branding/{{ branding_prefix }}_favicon.ico
      - JUPYTERHUB_BRANDING_LAB_MAIN_ICON_URI=file:///srv/branding/{{ branding_prefix }}_jl_logo.svg
      - JUPYTERLAB_SYSTEM_NAME={{ project_name }}
      - JUPYTERLAB_HEADER_CAPITALIZE_SYSTEM_NAME=1
    volumes:
      - ./branding:/srv/branding:ro
    networks:
      - jupyterhub_network
    labels:
      - "traefik.enable=true"

      # JupyterHub router. In IP mode the subdomain prefix never applies to
      # the IP itself (IPs can't carry subdomains), so route bare IP plus the
      # localhost subdomain via the regex. In DNS mode keep the standard
      # subdomain.<base> routing. The hub|jupyterhub|optimumhub|duoptimumhub
      # subdomains are accepted as transition aliases (base_url is /, so every
      # host serves transparently) - old URLs keep working until the cutover.
{%- if network_addressing == 'ip' %}
      - "traefik.http.routers.duoptimumhub-rtr.rule=Host(`${BASE_HOSTNAME}`) || HostRegexp(`^(hub|jupyterhub|optimumhub|duoptimumhub)\\.(.*\\.)?localhost$`) || HostRegexp(`^${JUPYTERHUB_PREFIX}(.*\\.)?localhost$`)"
{%- else %}
      - "traefik.http.routers.duoptimumhub-rtr.rule=Host(`${JUPYTERHUB_PREFIX}${BASE_HOSTNAME}`) || Host(`hub.${BASE_HOSTNAME}`) || Host(`jupyterhub.${BASE_HOSTNAME}`) || Host(`optimumhub.${BASE_HOSTNAME}`) || Host(`duoptimumhub.${BASE_HOSTNAME}`) || HostRegexp(`^(hub|jupyterhub|optimumhub|duoptimumhub)\\.(.*\\.)?localhost$`) || HostRegexp(`^${JUPYTERHUB_PREFIX}(.*\\.)?localhost$`)"
{%- endif %}
      - "traefik.http.routers.duoptimumhub-rtr.entrypoints=websecure"
      - "traefik.http.routers.duoptimumhub-rtr.tls=true"
      - "traefik.http.routers.duoptimumhub-rtr.service=duoptimumhub-svc"
      - "traefik.http.services.duoptimumhub-svc.loadbalancer.server.scheme=http"
      - "traefik.http.services.duoptimumhub-svc.loadbalancer.server.port=8000"

  watchtower:
    networks:
      - jupyterhub_network

networks:
  jupyterhub_network:
    name: ${COMPOSE_PROJECT_NAME:-jupyterhub}_network  # actual Docker network name namespaced by compose project

# EOF
