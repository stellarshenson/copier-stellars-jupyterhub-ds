# =============================================================================
# Compose Override - {{ project_name }}
# =============================================================================
# DELTAS ONLY. Everything else is inherited from the upstream compose.yml and
# NOT repeated here: hub image / volumes / ports / healthcheck, the
# hub-svc + hub-ratelimit middleware, hub_network / hub_gpuinfo_network,
# watchtower. Compose merges labels + environment by key (repeat the exact key
# to change a base value); `command` is replaced wholesale.
#
# PORTS:  80 (HTTP -> redirects to 443)  |  443 (HTTPS)
# CERT:   self-signed cert in ./certs/ -> the hub provisions it from
#         /user-certs into the shared hub_certs volume that Traefik watches.
#         Traefik does NOT bind-mount ./certs directly (base mount, inherited).
# ACCESS: https://${JUPYTERHUB_HOSTNAME_PREFIX}${BASE_HOSTNAME}/
#
# Set BASE_HOSTNAME and JUPYTERHUB_HOSTNAME_PREFIX in .env.
# =============================================================================
{%- set subs = jupyterhub_subdomain.split(',') | map('trim') | map('lower') | select | unique | list %}

services:

  # Local Traefik: enable TLS on the websecure entrypoint, secure the dashboard
  # (host routing, toggle via TRAEFIK_DASHBOARD_ENABLED), global http->https
  # redirect. `command` REPLACES the base command - it closes the insecure :8080
  # API, turns on websecure TLS, and namespace-scopes the docker provider to this
  # compose project. Image / ports / cert volume / network / restart are all
  # inherited from the base, which already mounts the hub-provisioned hub_certs:/certs.
  traefik:
    command:
      # Entrypoints
{%- if http_redirect %}
      - "--entrypoints.web.address=:80"
{%- endif %}
      - "--entrypoints.websecure.address=:443"
      - "--entrypoints.websecure.http.tls=true"

      # Docker provider
      - "--providers.docker=true"
      - "--providers.docker.exposedbydefault=false"
      # Namespace isolation: read labels ONLY from this compose project, else a
      # foreign stack's routers (e.g. its Traefik dashboard) leak in. Matches the
      # base compose default.
      - "--providers.docker.constraints=Label(`com.docker.compose.project`,`${COMPOSE_PROJECT_NAME:-duoptimum-hub}`)"

      # File provider for TLS certificates (hub-provisioned hub_certs volume)
      - "--providers.file.directory=/certs"
      - "--providers.file.watch=true"

      # API and Dashboard. Host-routed (no --api.basePath), so
      # TRAEFIK_DASHBOARD_ENABLED=false disables api@internal entirely and the
      # dashboard host 404s for both UI and API. Open (true) by default.
      - "--api.dashboard=${TRAEFIK_DASHBOARD_ENABLED:-true}"
      - "--api.insecure=false"

      # TLS configuration
      - "--serverstransport.insecureskipverify=true"

      # Logging
      - "--log.level=INFO"
    # Publish HTTPS on the configured host port (container side stays 443).
    # `!override` REPLACES the base ports list so only what we list is bound.
    # Port 80 (fixed) is published only when the http->https redirect is kept.
    ports: !override
{%- if http_redirect %}
      - "80:80"
{%- endif %}
      - "${TRAEFIK_HTTPS_PORT:-443}:443"
    labels:
      - "traefik.enable=true"
{%- if http_redirect %}

      # Global HTTP->HTTPS redirect (web entrypoint :80 -> the secure port)
      - "traefik.http.routers.http-catchall.rule=HostRegexp(`.+`)"
      - "traefik.http.routers.http-catchall.entrypoints=web"
      - "traefik.http.routers.http-catchall.middlewares=redirect-to-https"
      - "traefik.http.routers.http-catchall.priority=1"
      - "traefik.http.middlewares.redirect-to-https.redirectscheme.scheme=https"
      - "traefik.http.middlewares.redirect-to-https.redirectscheme.permanent=true"
{%- if traefik_https_port != 443 %}
      - "traefik.http.middlewares.redirect-to-https.redirectscheme.port={{ traefik_https_port }}"
{%- endif %}
{%- endif %}

      # Dashboard: traefik.${BASE_HOSTNAME}
      - "traefik.http.routers.dashboard.rule=Host(`traefik.${BASE_HOSTNAME}`) || HostRegexp(`^traefik(\\..+)?\\.localhost$`)"
      - "traefik.http.routers.dashboard.entrypoints=websecure"
      - "traefik.http.routers.dashboard.tls=true"
      - "traefik.http.routers.dashboard.service=api@internal"

  hub:
    # Override upstream's `pull_policy: build` - we don't have the Dockerfile
    # context locally (no upstream clone). Pull stellars/duoptimum-hub:latest
    # from Docker Hub instead. Network / ports / volumes (hub_certs, hub_data,
    # hub_shared, hub_docker, ./certs:/user-certs) are inherited from the base.
    pull_policy: missing
    environment:
      # main settings
      - JUPYTERHUB_BASE_URL=/
      - JUPYTERHUB_ADMIN={{ admin_username }} # initial admin username
      - JUPYTERHUB_ADMIN_PASSWORD=${JUPYTERHUB_ADMIN_PASSWORD:-} # optional INITIAL admin password from .env; ignored once admin sets one in the UI
      - JUPYTERHUB_IDLE_CULLER_ENABLED={% if idle_culler_enabled %}1{% else %}0{% endif %} # culler 0=disabled, 1=enabled
      - JUPYTERHUB_IDLE_CULLER_MAX_EXTENSION_MINUTES=2880 # max minutes users can extend a session (2880 = 48h)
      - JUPYTERHUB_SIGNUP_ENABLED={% if signup_enabled %}1{% else %}0{% endif %} # user self-registration: 0=disabled, 1=enabled
      - JUPYTERHUB_LAB_IMAGE=stellars/stellars-jupyterlab-ds:latest # user container image
      - JUPYTERHUB_TIMEZONE={{ timezone }} # timezone for hub and lab

      # branding ({{ project_name }})
      - JUPYTERHUB_BRANDING_HUB_NAME={{ project_name }} # portal brand-icon tooltip + login/signup text (else upstream default)
      - JUPYTERHUB_BRANDING_STAGE= # environment-stage header badge: DEV/STG/TST/PRD or custom text; empty = no badge
      - JUPYTERHUB_BRANDING_LOGO_URI=file:///srv/branding/{{ branding_prefix }}_jh_logo.png
      - JUPYTERHUB_BRANDING_FAVICON_URI=file:///srv/branding/{{ branding_prefix }}_favicon.ico
      - JUPYTERHUB_BRANDING_LAB_MAIN_ICON_URI=file:///srv/branding/{{ branding_prefix }}_jl_logo.svg
      - JUPYTERHUB_BRANDING_LAB_SPLASH_ICON_URI=file:///srv/branding/{{ branding_prefix }}_jl_logo.svg
      - JUPYTERHUB_BRANDING_LAB_NAME={{ project_name }} # lab display name; hub injects it into spawned labs as JUPYTERLAB_SYSTEM_NAME (header/welcome/MOTD)
    volumes:
      - ./branding:/srv/branding:ro
    labels:
      - "traefik.enable=true"

      # JupyterHub router. base_url is / here, so every accepted host serves the
      # hub transparently at the root. The configured subdomain(s) are baked in
      # at render time - one Host() matcher per subdomain, for `<sub>.<base>`
      # (network) and `<sub>.localhost` (host machine). A comma-separated
      # jupyterhub_subdomain renders multiple matchers; an empty value routes the
      # bare host. In IP mode the bare IP is the root URL and subdomains apply
      # only to the localhost side (IPs can't carry subdomains).
{%- if network_addressing == 'ip' %}
      - "traefik.http.routers.hub-rtr.rule=Host(`${BASE_HOSTNAME}`){% for s in subs %} || Host(`{{ s }}.localhost`){% endfor %}"
{%- else %}
      - "traefik.http.routers.hub-rtr.rule={% if subs %}{% for s in subs %}Host(`{{ s }}.${BASE_HOSTNAME}`){% if base_hostname != 'localhost' %} || Host(`{{ s }}.localhost`){% endif %}{% if not loop.last %} || {% endif %}{% endfor %}{% else %}Host(`${BASE_HOSTNAME}`){% if base_hostname != 'localhost' %} || Host(`localhost`){% endif %}{% endif %}"
{%- endif %}
      - "traefik.http.routers.hub-rtr.entrypoints=websecure"
      - "traefik.http.routers.hub-rtr.tls=true"
      - "traefik.http.routers.hub-rtr.service=hub-svc"
      # Override the inherited middleware chain to DROP hub-alias-redirect: that
      # redirect is only correct for the standalone PATH deployment (canonical
      # /jupyterhub). Here base_url is / so the hub's own paths ARE /hub/* and the
      # redirect would 302 them to /jupyterhub/* -> 404. Host aliases serve
      # transparently at /, so only the rate limiter applies.
      - "traefik.http.routers.hub-rtr.middlewares=hub-ratelimit"
      - "traefik.http.services.hub-svc.loadbalancer.server.scheme=http"
      - "traefik.http.services.hub-svc.loadbalancer.server.port=8000"

# EOF
