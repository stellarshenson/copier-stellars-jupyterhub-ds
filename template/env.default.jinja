# Default environment variables for the {{ project_name }} deployment.
# This file is tracked in git. To override any value below for local use,
# create a sibling `.env` file (gitignored) - start.sh and stop.sh source
# `env.default` first, then `.env` if present, so `.env` always wins.
COMPOSE_PROJECT_NAME={{ project_slug }}

# Domain for Traefik routing
BASE_HOSTNAME={{ base_hostname }}

# JupyterHub hostname prefix - primary subdomain (first of the list); empty serves at root domain
{% set subs = jupyterhub_subdomain.split(',') | map('trim') | map('lower') | select | unique | list -%}
JUPYTERHUB_HOSTNAME_PREFIX={% if subs %}{{ subs[0] }}.{% endif %}

# Host port Traefik publishes HTTPS on (container side stays 443)
TRAEFIK_HTTPS_PORT={{ traefik_https_port }}
{%- if cifs_shared_mount %}

# Enable CIFS mount for shared storage (0=disabled, 1=enabled)
ENABLE_CIFS=0
{%- endif %}
